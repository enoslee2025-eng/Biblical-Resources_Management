{
  "name": "获取资源列表",
  "method": "GET",
  "path": "/private/api/resource/list",
  "auth": true,
  "description": "获取当前用户的资源列表，可按类型筛选",
  "request": {
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "params": {
      "type": "资源类型（可选）"
    }
  },
  "response": {
    "code": 200,
    "message": "success",
    "data": [
      {
        "id": "资源ID",
        "type": "资源类型",
        "title": "资源标题",
        "metaJson": "元数据",
        "isPublic": 0,
        "version": 1,
        "createdAt": "创建时间",
        "updatedAt": "更新时间"
      }
    ]
  }
}
